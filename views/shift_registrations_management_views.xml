<odoo>
    <record id="t4_my_time_shift_registrations_management_list_view" model="ir.ui.view">
        <field name="name">t4.my.time.shift.registrations.management.list</field>
        <field name="model">t4.shift.registration</field>
        <field name="arch" type="xml">
            <list string="Shift Registrations"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'denied'"
                  decoration-warning="state == 'pending'">
                <field name="shift_id"/>
                <field name="employee_id"/>
                <field name="date_start"/>
                <field name="date_stop"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'denied'"/>
                <button name="action_approve"
                        string="Approve"
                        type="object"
                        icon="fa-check"
                        class="btn-success"
                        invisible="state != 'pending'"
                        title="Approve"/>
                <button name="action_deny"
                        string="Deny"
                        type="object"
                        icon="fa-times"
                        class="btn-danger"
                        invisible="state == 'denied'"
                        title="Deny"/>
            </list>
        </field>
    </record>

    <record id="t4_my_time_shift_registrations_management_form_view" model="ir.ui.view">
        <field name="name">t4.my.time.shift.registrations.management.form</field>
        <field name="model">t4.shift.registration</field>
        <field name="arch" type="xml">
            <form string="Shift Registration">
                <header>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_deny"
                            string="Deny"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'denied'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,approved,denied"/>
                </header>
                <sheet>
                    <group string="Registration Information">
                        <group>
                            <field name="shift_id"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_stop"/>
                        </group>
                        
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_my_time_shift_registrations_management_action" model="ir.actions.act_window">
        <field name="name">Shift Registrations Management</field>
        <field name="res_model">t4.shift.registration</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('t4_my_time_shift_registrations_management_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('t4_my_time_shift_registrations_management_form_view')})
        ]"/>
    </record>
</odoo>