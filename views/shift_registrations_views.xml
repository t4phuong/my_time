<odoo>
    <!-- Employee: Open Shifts Calendar View -->
    <record id="t4_my_time_shift_registrations_calendar_view" model="ir.ui.view">
        <field name="name">t4.my.time.shift.registrations.calendar</field>
        <field name="model">t4.shift</field>
        <field name="arch" type="xml">
            <calendar
                string="Open Shifts"
                date_start="date_start"
                date_stop="date_stop"
                color="department_id"
                quick_create="false"
                create="false"
                edit="false"
                delete="false"
                event_open_popup="true"
            >
            </calendar>
        </field>
    </record>

    <record id="t4_my_time_shift_registrations_form_view" model="ir.ui.view">
        <field name="name">t4.my.time.shift.registrations.form</field>
        <field name="model">t4.shift</field>
        <field name="arch" type="xml">
            <form
                string="Shift Detail"
                create="false"
                edit="false"
                delete="false"
            >
                <header>
                    <div class="alert alert-success" invisible="not is_registered_by_current_user">
                        You have already registered for this shift.
                    </div>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group col="2">
                        <group string="Schedule">
                            <field name="date_start" readonly="1"/>
                            <field name="date_stop" readonly="1"/>
                            <field name="work_entry_type_id" readonly="1"/>
                        </group>

                        <group string="Requirement">
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Slots -->
                    <group string="Slots">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold text-muted">
                                Registrations:
                            </span>
                            <div>
                                <field name="registered_count" readonly="1" class="oe_inline"/>
                                <span class="mx-1">/</span>
                                <field name="max_employee" readonly="1" class="oe_inline"/>
                            </div>
                        </div>
                    </group>

                    <!-- Note -->
                    <group string="Note">
                        <field
                            name="note"
                            readonly="1"
                            nolabel="1"
                            placeholder="No note"
                        />
                    </group>
                </sheet>
                <footer>
                    <button
                        name="action_register_shift"
                        type="object"
                        string="Register"
                        class="btn-primary"
                        invisible="state != 'open' or is_registered_by_current_user"
                    />
                    <button
                        string="Close"
                        special="cancel"
                        class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <!-- Employee: Open Shifts Action -->
    <record id="t4_my_time_shift_registrations_action" model="ir.actions.act_window">
        <field name="name">Available Shifts</field>
        <field name="res_model">t4.shift</field>
        <field name="view_mode">calendar,form</field>
        <field name="context">
            {
                'create': False,
                'edit': False,
                'delete': False,
                'form_view_initial_mode': 'view'
            }
        </field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'calendar', 'view_id': ref('t4_my_time_shift_registrations_calendar_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('t4_my_time_shift_registrations_form_view')})
        ]"/>

    </record>

</odoo>